generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  // Used only by prisma migrate. On Supabase this must be the direct
  // (non-pooled) connection string; locally it's the same as DATABASE_URL.
  directUrl = env("DIRECT_URL")
}

enum Role {
  ADMIN
  CLIENT
  /// Limited team member: projects + client messages only, all money hidden.
  STAFF
}

enum UserStatus {
  ACTIVE
  INACTIVE
}

enum ProjectType {
  SHOPIFY
  WORDPRESS
  WEBFLOW
  CUSTOM_WEB_DEV
  APP_DEV
  UI_DESIGN_FIGMA
}

enum ProjectSource {
  FIVERR
  UPWORK
  INDEPENDENT
  DEED
}

enum Priority {
  HIGH
  MEDIUM
  LOW
}

enum ProjectStatus {
  PLANNING
  IN_PROGRESS
  REVIEW
  COMPLETED
}

enum MilestoneStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
}

enum PricingType {
  NONE
  HOURLY
  FIXED
}

enum InvoiceStatus {
  ASSIGNED
  SENT
  IN_REVIEW
  PAID
}

enum TaskRequestStatus {
  PENDING
  APPROVED
  REJECTED
}

enum NotificationType {
  TASK_REQUEST_SUBMITTED
  TASK_REQUEST_APPROVED
  TASK_REQUEST_REJECTED
  INVOICE_SENT
  MILESTONE_COMPLETED
  MILESTONE_UPDATED
  MESSAGE_RECEIVED
  MILESTONE_APPROVED
  PAYMENT_CLAIMED
  MEETING_SCHEDULED
  MEETING_CANCELLED
  RETAINER_GENERATED
  PROPOSAL_ACCEPTED
}

enum MeetingStatus {
  SCHEDULED
  CANCELLED
}

enum LeadStage {
  NEW
  CONTACTED
  PROPOSAL
  WON
  LOST
}

enum ProposalStatus {
  DRAFT
  SENT
  ACCEPTED
  DECLINED
  EXPIRED
}

enum LeadSource {
  FIVERR
  UPWORK
  REFERRAL
  WEBSITE
  OTHER
}

enum PaymentRegion {
  US_ACH
  INTERNATIONAL_SWIFT
  EU_SEPA
}

enum MessageSenderRole {
  ADMIN
  CLIENT
}

enum ProjectBillingType {
  MILESTONE
  CONTRACT
}

enum CampaignStatus {
  DRAFT
  SENDING
  SENT
  FAILED
}

model User {
  id            String     @id @default(cuid())
  email         String     @unique
  emailVerified Boolean    @default(false)
  name          String
  firstName     String     @default("")
  lastName      String     @default("")
  role          Role       @default(CLIENT)
  company       String?
  phone         String?
  status        UserStatus @default(ACTIVE)
  image         String?
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  /// Opted out of marketing campaign emails (transactional emails unaffected).
  marketingOptOut Boolean @default(false)
  /// Set when the client has seen the first-login welcome guide.
  onboardedAt     DateTime?
  /// IANA timezone (e.g. "America/New_York"): auto-captured from the client's
  /// browser on portal load, editable by the admin.
  timezone        String?

  sessions           Session[]
  accounts           Account[]
  projects           Project[]
  invoices           Invoice[]
  taskRequests       TaskRequest[]
  notifications      Notification[]
  imageUploads       ImageUpload[]
  messages           Message[]
  clientMessages     Message[]           @relation("ClientMessages")
  campaignRecipients CampaignRecipient[]
  meetings           Meeting[]           @relation("ClientMeetings")
  retainers          Retainer[]          @relation("ClientRetainers")

  @@index([role, status])
  @@map("users")
}

model Session {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  expiresAt DateTime
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("sessions")
}

model Account {
  id                    String    @id @default(cuid())
  userId                String
  accountId             String
  providerId            String
  password              String?
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("accounts")
}

model Verification {
  id         String   @id @default(cuid())
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([identifier])
  @@map("verifications")
}

model Project {
  id          String        @id @default(cuid())
  projectName String
  clientId    String?
  client      User?         @relation(fields: [clientId], references: [id], onDelete: SetNull)
  type        ProjectType
  source      ProjectSource @default(INDEPENDENT)
  priority    Priority      @default(MEDIUM)
  status      ProjectStatus @default(PLANNING)
  /// MILESTONE = per-milestone pricing (default); CONTRACT = one fixed
  /// whole-project price (milestone pricing hidden/ignored, not deleted).
  billingType   ProjectBillingType @default(MILESTONE)
  contractPrice Decimal?           @db.Decimal(10, 2)
  description Json?
  startDate   DateTime?
  dueDate     DateTime?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  milestones   Milestone[]
  invoices     Invoice[]
  taskRequests TaskRequest[]
  messages     Message[]
  meetings     Meeting[]
  retainers    Retainer[]

  @@index([clientId])
  @@index([status])
  @@map("projects")
}

model Milestone {
  id                  String          @id @default(cuid())
  title               String
  projectId           String
  project             Project         @relation(fields: [projectId], references: [id], onDelete: Cascade)
  status              MilestoneStatus @default(PENDING)
  position            Int
  description         Json?
  pricingType         PricingType     @default(NONE)
  hourlyRate          Decimal?        @db.Decimal(10, 2)
  estimatedHours      Decimal?        @db.Decimal(6, 2)
  fixedPrice          Decimal?        @db.Decimal(10, 2)
  sourceTaskRequestId String?         @unique
  sourceTaskRequest   TaskRequest?    @relation(fields: [sourceTaskRequestId], references: [id], onDelete: SetNull)
  /// Set when the client approves this milestone after completion.
  clientApprovedAt    DateTime?
  createdAt           DateTime        @default(now())
  updatedAt           DateTime        @updatedAt

  timeEntries TimeEntry[]

  @@index([projectId, position])
  @@map("milestones")
}

/// A logged unit of work on a milestone: when, how many hours, and an
/// optional progress note. Admin-created; shown to the client on the
/// portal timeline. Deliberately creates NO notifications or emails.
model TimeEntry {
  id          String    @id @default(cuid())
  milestoneId String
  milestone   Milestone @relation(fields: [milestoneId], references: [id], onDelete: Cascade)
  date        DateTime  @db.Date
  hours       Decimal   @db.Decimal(6, 2)
  note        String?
  createdAt   DateTime  @default(now())

  @@index([milestoneId, date])
  @@map("time_entries")
}

model Invoice {
  id              String        @id @default(cuid())
  invoiceNumber   String        @unique
  clientId        String
  client          User          @relation(fields: [clientId], references: [id], onDelete: Restrict)
  projectId       String?
  project         Project?      @relation(fields: [projectId], references: [id], onDelete: SetNull)
  amount          Decimal       @db.Decimal(10, 2)
  status          InvoiceStatus @default(ASSIGNED)
  pdfPath         String?
  pdfOriginalName String?
  /// External file link (e.g. Google Drive/Dropbox). When set, invoice
  /// downloads redirect here instead of serving an uploaded PDF.
  pdfExternalUrl  String?
  issueDate       DateTime
  dueDate         DateTime?
  notes           String?
  sentAt          DateTime?
  /// Set when the client reports having sent the payment; admin confirms
  /// by moving the status to PAID.
  paymentClaimedAt DateTime?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@index([clientId])
  @@index([status])
  @@map("invoices")
}

model TaskRequest {
  id          String            @id @default(cuid())
  title       String
  description Json
  projectId   String
  project     Project           @relation(fields: [projectId], references: [id], onDelete: Cascade)
  clientId    String
  client      User              @relation(fields: [clientId], references: [id], onDelete: Cascade)
  status      TaskRequestStatus @default(PENDING)
  adminNote   String?
  resolvedAt  DateTime?
  milestone   Milestone?
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  @@index([status])
  @@index([clientId])
  @@index([projectId])
  @@map("task_requests")
}

model Notification {
  id        String           @id @default(cuid())
  userId    String
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      NotificationType
  title     String
  body      String?
  link      String?
  readAt    DateTime?
  createdAt DateTime         @default(now())

  @@index([userId, readAt])
  @@index([userId, createdAt])
  @@map("notifications")
}

model ImageUpload {
  id           String   @id @default(uuid())
  fileName     String   @unique
  originalName String
  mimeType     String
  size         Int
  uploaderId   String
  uploader     User     @relation(fields: [uploaderId], references: [id], onDelete: Cascade)
  createdAt    DateTime @default(now())

  @@index([uploaderId])
  @@map("image_uploads")
}

model Counter {
  name  String @id
  value Int    @default(0)

  @@map("counters")
}

/// A prospect in the sales pipeline; may be converted into a client.
model Lead {
  id                String     @id @default(cuid())
  name              String
  email             String?
  company           String?
  source            LeadSource @default(OTHER)
  stage             LeadStage  @default(NEW)
  estimatedValue    Decimal?   @db.Decimal(10, 2)
  notes             String?
  /// What we know about their brand/business (context for the pitch).
  brandInfo         String?
  /// The reply we sent (or plan to send) — copyable for Fiverr/Upwork/email.
  responseMessage   String?
  nextFollowUp      DateTime?
  convertedClientId String?
  createdAt         DateTime   @default(now())
  updatedAt         DateTime   @updatedAt
  proposals         Proposal[]

  @@index([stage, nextFollowUp])
  @@map("leads")
}

/// A branded proposal: intro + line-item scope + total + timeline + deposit %.
/// Sent as a signed, expiring public link; the prospect accepts by typing their
/// name (acceptedName), or the admin closes it on their behalf (acceptedByAdmin
/// — e.g. they said yes on a call). Either way the app creates the client
/// account + a CONTRACT project + a draft deposit invoice.
///
/// The recipient comes from EITHER a pipeline lead (leadId) OR the manually
/// entered recipient* fields — exactly one is set. Accepting a lead-backed
/// proposal also marks that lead WON.
/// Total is always derived from items (never trust a client-supplied value).
model Proposal {
  id                 String         @id @default(cuid())
  leadId             String?
  lead               Lead?          @relation(fields: [leadId], references: [id], onDelete: Cascade)
  /// Set only for manually-created proposals (no lead behind them).
  recipientName      String?
  recipientEmail     String?
  recipientCompany   String?
  title              String
  intro              String?
  projectType        ProjectType
  timelineWeeks      Int?
  depositPercent     Int            @default(50)
  /// Validity window chosen in the builder; applied when the proposal is sent.
  expiresInDays      Int            @default(30)
  /// Optional invoice document attached in the builder — either an uploaded
  /// PDF or an external link (Drive/Dropbox). Copied onto the deposit invoice
  /// that acceptance creates, so the client gets the paperwork immediately.
  invoicePdfPath         String?
  invoicePdfOriginalName String?
  invoicePdfExternalUrl  String?
  status             ProposalStatus @default(DRAFT)
  expiresAt          DateTime?
  sentAt             DateTime?
  acceptedAt         DateTime?
  acceptedName       String?
  /// True when the admin marked it accepted rather than the client signing.
  acceptedByAdmin    Boolean        @default(false)
  convertedClientId  String?
  convertedProjectId String?
  convertedInvoiceId String?
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt
  items              ProposalItem[]

  @@index([leadId])
  @@index([status])
  @@map("proposals")
}

model ProposalItem {
  id          String   @id @default(cuid())
  proposalId  String
  proposal    Proposal @relation(fields: [proposalId], references: [id], onDelete: Cascade)
  description String
  amount      Decimal  @db.Decimal(10, 2)
  sortOrder   Int      @default(0)

  @@index([proposalId])
  @@map("proposal_items")
}

/// A monthly maintenance/retainer plan. The duties engine drafts one invoice
/// per period (lastGeneratedPeriod = "YYYY-MM") on/after dayOfMonth; the
/// admin reviews and sends it with the normal invoice flow.
model Retainer {
  id                  String   @id @default(cuid())
  clientId            String
  client              User     @relation("ClientRetainers", fields: [clientId], references: [id], onDelete: Cascade)
  projectId           String?
  project             Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)
  title               String
  amount              Decimal  @db.Decimal(10, 2)
  dayOfMonth          Int      @default(1)
  active              Boolean  @default(true)
  lastGeneratedPeriod String?
  notes               String?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@index([active, dayOfMonth])
  @@map("retainers")
}

/// A meeting the admin booked with a client. startsAt is a UTC instant;
/// each side sees it rendered in their own timezone.
model Meeting {
  id           String        @id @default(cuid())
  clientId     String
  client       User          @relation("ClientMeetings", fields: [clientId], references: [id], onDelete: Cascade)
  projectId    String?
  project      Project?      @relation(fields: [projectId], references: [id], onDelete: SetNull)
  title        String
  notes        String?
  startsAt     DateTime
  durationMins Int           @default(30)
  meetingUrl   String?
  status       MeetingStatus @default(SCHEDULED)
  /// Set once the 24h-before reminder email went out (duties engine).
  reminderSentAt DateTime?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  @@index([startsAt])
  @@index([clientId, startsAt])
  @@map("meetings")
}

/// Simple key-value store for admin-editable app settings
/// (e.g. the WhatsApp support link shown to clients).
model AppSetting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt

  @@map("app_settings")
}

/// Bank-transfer payment accounts shown to clients (admin-managed). The
/// `fields` JSON is an ordered [{label, value}] list so each region can carry
/// its own set (ACH routing/account vs IBAN/SWIFT vs IBAN/sort-code).
model PaymentAccount {
  id         String        @id @default(cuid())
  title      String
  region     PaymentRegion
  holderName String
  bankName   String
  bankNote   String?
  fields     Json
  note       String?
  isActive   Boolean       @default(true)
  position   Int           @default(0)
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt

  @@index([isActive, position])
  @@map("payment_accounts")
}

/// A message in a per-project thread between the agency (admin) and the client.
/// A message between the agency (admin) and a client. A thread is identified
/// by (clientId, projectId): projectId = null is the client's GENERAL thread,
/// i.e. chatting with us without picking a project.
model Message {
  id             String            @id @default(cuid())
  clientId       String
  client         User              @relation("ClientMessages", fields: [clientId], references: [id], onDelete: Cascade)
  projectId      String?
  project        Project?          @relation(fields: [projectId], references: [id], onDelete: Cascade)
  senderId       String
  sender         User              @relation(fields: [senderId], references: [id], onDelete: Cascade)
  senderRole     MessageSenderRole
  body           Json
  readByAdminAt  DateTime?
  readByClientAt DateTime?
  createdAt      DateTime          @default(now())

  @@index([clientId, projectId, createdAt])
  @@index([projectId, createdAt])
  @@map("messages")
}

/// Reusable marketing email template (subject + Tiptap body).
model EmailTemplate {
  id        String   @id @default(cuid())
  name      String
  subject   String
  body      Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  campaigns Campaign[]

  @@map("email_templates")
}

/// A marketing send: snapshot of subject/body plus per-recipient status rows.
model Campaign {
  id         String         @id @default(cuid())
  subject    String
  body       Json
  templateId String?
  template   EmailTemplate? @relation(fields: [templateId], references: [id], onDelete: SetNull)
  status     CampaignStatus @default(DRAFT)
  sentAt     DateTime?
  createdAt  DateTime       @default(now())

  recipients CampaignRecipient[]

  @@index([createdAt])
  @@map("campaigns")
}

model CampaignRecipient {
  id         String    @id @default(cuid())
  campaignId String
  campaign   Campaign  @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  userId     String
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  sentAt     DateTime?
  error      String?

  @@unique([campaignId, userId])
  @@index([userId])
  @@map("campaign_recipients")
}
