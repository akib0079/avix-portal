generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  CLIENT
}

enum UserStatus {
  ACTIVE
  INACTIVE
}

enum ProjectType {
  SHOPIFY
  WORDPRESS
  WEBFLOW
  CUSTOM_WEB_DEV
  APP_DEV
  UI_DESIGN_FIGMA
}

enum ProjectSource {
  FIVERR
  UPWORK
  INDEPENDENT
  DEED
}

enum Priority {
  HIGH
  MEDIUM
  LOW
}

enum ProjectStatus {
  PLANNING
  IN_PROGRESS
  REVIEW
  COMPLETED
}

enum MilestoneStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
}

enum PricingType {
  NONE
  HOURLY
  FIXED
}

enum InvoiceStatus {
  ASSIGNED
  SENT
  IN_REVIEW
  PAID
}

enum TaskRequestStatus {
  PENDING
  APPROVED
  REJECTED
}

enum NotificationType {
  TASK_REQUEST_SUBMITTED
  TASK_REQUEST_APPROVED
  TASK_REQUEST_REJECTED
  INVOICE_SENT
}

model User {
  id            String     @id @default(cuid())
  email         String     @unique
  emailVerified Boolean    @default(false)
  name          String
  firstName     String     @default("")
  lastName      String     @default("")
  role          Role       @default(CLIENT)
  company       String?
  phone         String?
  status        UserStatus @default(ACTIVE)
  image         String?
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  sessions      Session[]
  accounts      Account[]
  projects      Project[]
  invoices      Invoice[]
  taskRequests  TaskRequest[]
  notifications Notification[]
  imageUploads  ImageUpload[]

  @@index([role, status])
  @@map("users")
}

model Session {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  expiresAt DateTime
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("sessions")
}

model Account {
  id                    String    @id @default(cuid())
  userId                String
  accountId             String
  providerId            String
  password              String?
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("accounts")
}

model Verification {
  id         String   @id @default(cuid())
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([identifier])
  @@map("verifications")
}

model Project {
  id          String        @id @default(cuid())
  projectName String
  clientId    String?
  client      User?         @relation(fields: [clientId], references: [id], onDelete: SetNull)
  type        ProjectType
  source      ProjectSource @default(INDEPENDENT)
  priority    Priority      @default(MEDIUM)
  status      ProjectStatus @default(PLANNING)
  description Json?
  startDate   DateTime?
  dueDate     DateTime?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  milestones   Milestone[]
  invoices     Invoice[]
  taskRequests TaskRequest[]

  @@index([clientId])
  @@index([status])
  @@map("projects")
}

model Milestone {
  id                  String          @id @default(cuid())
  title               String
  projectId           String
  project             Project         @relation(fields: [projectId], references: [id], onDelete: Cascade)
  status              MilestoneStatus @default(PENDING)
  position            Int
  description         Json?
  pricingType         PricingType     @default(NONE)
  hourlyRate          Decimal?        @db.Decimal(10, 2)
  estimatedHours      Decimal?        @db.Decimal(6, 2)
  fixedPrice          Decimal?        @db.Decimal(10, 2)
  sourceTaskRequestId String?         @unique
  sourceTaskRequest   TaskRequest?    @relation(fields: [sourceTaskRequestId], references: [id], onDelete: SetNull)
  createdAt           DateTime        @default(now())
  updatedAt           DateTime        @updatedAt

  @@index([projectId, position])
  @@map("milestones")
}

model Invoice {
  id              String        @id @default(cuid())
  invoiceNumber   String        @unique
  clientId        String
  client          User          @relation(fields: [clientId], references: [id], onDelete: Restrict)
  projectId       String?
  project         Project?      @relation(fields: [projectId], references: [id], onDelete: SetNull)
  amount          Decimal       @db.Decimal(10, 2)
  status          InvoiceStatus @default(ASSIGNED)
  pdfPath         String?
  pdfOriginalName String?
  issueDate       DateTime
  dueDate         DateTime?
  notes           String?
  sentAt          DateTime?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@index([clientId])
  @@index([status])
  @@map("invoices")
}

model TaskRequest {
  id          String            @id @default(cuid())
  title       String
  description Json
  projectId   String
  project     Project           @relation(fields: [projectId], references: [id], onDelete: Cascade)
  clientId    String
  client      User              @relation(fields: [clientId], references: [id], onDelete: Cascade)
  status      TaskRequestStatus @default(PENDING)
  adminNote   String?
  resolvedAt  DateTime?
  milestone   Milestone?
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  @@index([status])
  @@index([clientId])
  @@index([projectId])
  @@map("task_requests")
}

model Notification {
  id        String           @id @default(cuid())
  userId    String
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      NotificationType
  title     String
  body      String?
  link      String?
  readAt    DateTime?
  createdAt DateTime         @default(now())

  @@index([userId, readAt])
  @@index([userId, createdAt])
  @@map("notifications")
}

model ImageUpload {
  id           String   @id @default(uuid())
  fileName     String   @unique
  originalName String
  mimeType     String
  size         Int
  uploaderId   String
  uploader     User     @relation(fields: [uploaderId], references: [id], onDelete: Cascade)
  createdAt    DateTime @default(now())

  @@index([uploaderId])
  @@map("image_uploads")
}

model Counter {
  name  String @id
  value Int    @default(0)

  @@map("counters")
}
